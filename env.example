# Environment Configuration Example
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_REGION=us-east-1
USE_SAGEMAKER=false  # Set to true in production

# S3 Buckets (production)
S3_RAW_BUCKET=mlops-toxic-dev-raw-data
S3_PROCESSED_BUCKET=mlops-toxic-dev-processed
S3_MODELS_BUCKET=mlops-toxic-dev-models
S3_EVIDENTLY_BUCKET=mlops-toxic-dev-evidently

# SageMaker
SAGEMAKER_ENDPOINT_NAME=mlops-toxic-dev-endpoint
SAGEMAKER_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/mlops-toxic-dev-sagemaker-execution-role

# RDS Configuration
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=reviews
RDS_USER=admin
RDS_PASSWORD=your-password

# Or use Secrets Manager
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:mlops-toxic-dev-rds-credentials

# MinIO Configuration (local development)
USE_LOCAL_MINIO=true
MINIO_ENDPOINT_LOCAL=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000

# Monitoring
ENABLE_CLOUDWATCH=false  # Set to true in production
ENABLE_EVIDENTLY=false
CLOUDWATCH_NAMESPACE=ToxicCommentAPI
DRIFT_THRESHOLD=0.15

# SNS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:mlops-toxic-dev-alerts

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
MODEL_VERSION=v1.0.0

# Review UI Configuration
REVIEW_HOST=0.0.0.0
REVIEW_PORT=5001
REVIEW_AUTH_USERNAME=admin
REVIEW_AUTH_PASSWORD=changeme

# Moderation Thresholds
THRESHOLD_BAN_SEVERE_TOXIC=0.7
THRESHOLD_BAN_THREAT=0.6
THRESHOLD_BAN_TOXIC=0.85
THRESHOLD_BAN_OBSCENE=0.8
THRESHOLD_BAN_INSULT=0.8
THRESHOLD_BAN_IDENTITY_HATE=0.7
THRESHOLD_REVIEW_MIN=0.5

# Model Promotion
MODEL_PROMOTION_THRESHOLD=0.02
